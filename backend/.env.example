# Pooler URL — used by the app at runtime (supports many short-lived connections)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Direct URL — used by Prisma migrate & seeder (bypasses pooler, no timeout on long ops)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

PORT=3001
FRONTEND_URL="http://localhost:5173"
