generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int      @id @default(autoincrement())
  sbd         String   @unique @db.Char(8)
  toan        Decimal? @db.Decimal(4, 2)
  ngu_van     Decimal? @db.Decimal(4, 2)
  ngoai_ngu   Decimal? @db.Decimal(4, 2)
  vat_li      Decimal? @db.Decimal(4, 2)
  hoa_hoc     Decimal? @db.Decimal(4, 2)
  sinh_hoc    Decimal? @db.Decimal(4, 2)
  lich_su     Decimal? @db.Decimal(4, 2)
  dia_li      Decimal? @db.Decimal(4, 2)
  gdcd        Decimal? @db.Decimal(4, 2)
  ma_ngoai_ngu String? @db.VarChar(4)
  created_at  DateTime @default(now())

  @@index([sbd])
  @@map("students")
}

model TopGroupA {
  id          Int      @id @default(autoincrement())
  sbd         String   @unique @db.Char(8)
  toan        Decimal? @db.Decimal(4, 2)
  vat_li      Decimal? @db.Decimal(4, 2)
  hoa_hoc     Decimal? @db.Decimal(4, 2)
  total_score Decimal? @db.Decimal(4, 2)
  created_at  DateTime @default(now())

  @@index([sbd])
  @@map("top_group_a")
}