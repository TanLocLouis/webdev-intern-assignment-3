generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                  BigInt   @id @default(autoincrement())
  registration_number String   @unique @db.VarChar(20)
  ma_ngoai_ngu        String?  @db.VarChar(4)
  created_at          DateTime @default(now()) @map("created_at")
  updated_at          DateTime @default(now()) @updatedAt @map("updated_at")

  scores              Score[]

  @@index([registration_number])
  @@map("students")
}

model Subject {
  id    Int     @id @default(autoincrement())
  name  String  @unique @db.VarChar(50)
  code  String  @unique @db.VarChar(10)

  scores Score[]

  @@map("subjects")
}

model Score {
  id         BigInt  @id @default(autoincrement())
  student_id BigInt  @map("student_id")
  subject_id Int     @map("subject_id")
  score      Decimal @db.Decimal(4, 2)

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_id, subject_id], name: "unique_student_subject")
  @@map("scores")
}